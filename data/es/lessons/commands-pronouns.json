    [
        "article",
        {},
        [
            "p",
            {
                "className": "section-intro"
            },
            "The position of object pronouns changes depending on whether a command is affirmative or negative."
        ],
        [
            "section",
            {
                "className": "module-section"
            },
            [
                "h2",
                {},
                "Affirmative Commands"
            ],
            [
                "p",
                {},
                "In affirmative commands, pronouns are ",
                [
                    "strong",
                    {},
                    "attached"
                ],
                " to the end of the verb."
            ],
            [
                "p",
                {
                    "className": "spanish"
                },
                "Dí",
                [
                    "strong",
                    {},
                    "melo"
                ],
                ". (Tell it to me.)"
            ],
            [
                "p",
                {
                    "className": "spanish"
                },
                "Cómpre",
                [
                    "strong",
                    {},
                    "lo"
                ],
                ". (Buy it.)"
            ],
            [
                "p",
                {},
                "Note: Adding a pronoun often requires adding an accent mark to maintain the original stress."
            ]
        ],
        [
            "section",
            {
                "className": "module-section"
            },
            [
                "h2",
                {},
                "Negative Commands"
            ],
            [
                "p",
                {},
                "In negative commands, pronouns come ",
                [
                    "strong",
                    {},
                    "before"
                ],
                " the verb (and after 'no')."
            ],
            [
                "p",
                {
                    "className": "spanish"
                },
                "No ",
                [
                    "strong",
                    {},
                    "me lo"
                ],
                " diga. (Don't tell it to me.)"
            ],
            [
                "p",
                {
                    "className": "spanish"
                },
                "No ",
                [
                    "strong",
                    {},
                    "lo"
                ],
                " compre. (Don't buy it.)"
            ]
        ]
    ]
]