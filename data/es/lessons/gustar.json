            "Gustar"
        ]
    ],
    [
        "article",
        {},
        [
            "p",
            {
                "className": "section-intro"
            },
            "The verb ",
            [
                "strong",
                {},
                "gustar"
            ],
            " doesn't mean 'to like' in the way English does. It literally means 'to be pleasing to.'"
        ],
        [
            "section",
            {
                "className": "module-section"
            },
            [
                "h2",
                {},
                "The Structure"
            ],
            [
                "p",
                {},
                "The thing being 'liked' is actually the subject of the sentence. Therefore, we mostly use only two forms: ",
                [
                    "strong",
                    {},
                    "gusta"
                ],
                " (singular) and ",
                [
                    "strong",
                    {},
                    "gustan"
                ],
                " (plural)."
            ],
            [
                "ul",
                {
                    "className": "phrase-list"
                },
                [
                    "li",
                    {},
                    [
                        "span",
                        {
                            "className": "spanish"
                        },
                        "Me gusta el café."
                    ],
                    [
                        "span",
                        {
                            "className": "meaning"
                        },
                        "I like coffee (Coffee is pleasing to me)."
                    ]
                ],
                [
                    "li",
                    {},
                    [
                        "span",
                        {
                            "className": "spanish"
                        },
                        "Me gustan los libros."
                    ],
                    [
                        "span",
                        {
                            "className": "meaning"
                        },
                        "I like books (Books are pleasing to me)."
                    ]
                ]
            ]
        ],
        [
            "div",
            {
                "className": "grammar-info"
            },
            [
                "h3",
                {},
                "Indirect Object Pronouns"
            ],
            [
                "p",
                {},
                "You must use a pronoun with gustar to show who is pleased:"
            ],
            [
                "p",
                {},
                [
                    "strong",
                    {},
                    "me, te, le, nos, os, les"
                ]
            ],
            [
                "p",
                {
                    "className": "spanish"
                },
                "¿Te gusta la música?"
            ]
        ]
    ]
