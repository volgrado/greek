[
    "div",
    {
        "className": "content-wrapper"
    },
    [
        "header",
        {
            "className": "lesson-header"
        },
        [
            "p",
            {
                "className": "lesson-meta"
            },
            "Lesson 47"
        ],
        [
            "h1",
            {},
            "Irregular Present Participles"
        ]
    ],
    [
        "article",
        {},
        [
            "p",
            {
                "className": "section-intro"
            },
            "Some verbs have irregular present participles, often due to spelling changes or stem-shifts."
        ],
        [
            "section",
            {
                "className": "module-section"
            },
            [
                "h2",
                {},
                "The '-yendo' Group"
            ],
            [
                "p",
                {},
                "When the stem of an -er or -ir verb ends in a vowel, use ",
                [
                    "strong",
                    {},
                    "-yendo"
                ],
                " instead of -iendo."
            ],
            [
                "ul",
                {
                    "className": "rule-list"
                },
                [
                    "li",
                    {},
                    "Leer → ",
                    [
                        "strong",
                        {},
                        "leyendo"
                    ]
                ],
                [
                    "li",
                    {},
                    "Oír → ",
                    [
                        "strong",
                        {},
                        "oyendo"
                    ]
                ],
                [
                    "li",
                    {},
                    "Traer → ",
                    [
                        "strong",
                        {},
                        "trayendo"
                    ]
                ]
            ]
        ],
        [
            "section",
            {
                "className": "module-section"
            },
            [
                "h2",
                {},
                "Stem-Changing Verbs"
            ],
            [
                "p",
                {},
                "Only -ir stem-changing verbs keep their change in the participle."
            ],
            [
                "ul",
                {
                    "className": "phrase-list"
                },
                [
                    "li",
                    {},
                    "e → i: ",
                    [
                        "strong",
                        {},
                        "Diciendo"
                    ],
                    " (from decir)"
                ],
                [
                    "li",
                    {},
                    "o → u: ",
                    [
                        "strong",
                        {},
                        "Durmiendo"
                    ],
                    " (from dormir)"
                ]
            ]
        ]
    ]
]