        ],
        [
            "section",
            {
                "className": "module-section"
            },
            [
                "h2",
                {},
                "Using 'Quien'"
            ],
            [
                "p",
                {},
                "Use 'quien' when referring to people after prepositions like ",
                [
                    "strong",
                    {},
                    "a, con, de, para"
                ],
                "."
            ],
            [
                "ul",
                {
