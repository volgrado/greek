                    {},
                    "Indicative"
                ],
                "."
            ],
            [
                "p",
                {},
                "Pattern: ",
                [
                    "strong",
                    {},
                    "Si + Present Indicative → Present/Future Indicative"
                ]
            ],
            [
                "div",
                {
                    "className": "example-box"
