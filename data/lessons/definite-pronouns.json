            ]
          ],
          [
            "div",
            {
              "className": "content"
            },
            [
              "p",
              {},
              "Often accompanied by a weak possessive pronoun (",
              [
                "span",
                {
                  "className": "greek-text"
                },
                "μου, σου..."
              ],
              ") to mean \"by myself\"."
            ],
            [
              "div",
              {
                "className": "example mt-4"
              },
              [
                "span",
                {
                  "className": "greek-text"
                },
                "Το τελείωσα",
                " ",
                [
                  "strong",
                  {},
                  "μόνος μου"
                ],
                "."
              ],
              " ",
              [
                "span",
                {
                  "className": "translation"
                },
                "I finished it",
                " ",
                [
                  "strong",
                  {},
                  "by myself"
                ],
                "."
              ]
            ]
          ]
        ]
      ],
      [
        "div",
