  [
    "article",
    {},
    [
      "section",
      {},
      [
        "p",
        {},
        "Definite pronouns in Greek are used to express identity (\"the same\")\n            or exclusivity (\"alone / by oneself\")."
      ],
      [
        "div",
        {
          "className": "definite-grid mt-8"
        },
        [
          "div",
          {
            "className": "definite-card "
          },
          [
            "header",
            {},
            [
              "span",
              {
                "className": "greek-text"
              },
              "ίδιος, ίδια, ίδιο"
            ],
            [
              "h3",
              {},
              "The Same"
            ]
          ],
          [
            "div",
            {
              "className": "content"
            },
            [
              "p",
              {},
              "Always used with a definite article."
            ],
            [
              "div",
              {
                "className": "example mt-4"
              },
              [
                "span",
                {
                  "className": "greek-text"
                },
                "Πήγα στον",
                " ",
                [
                  "strong",
                  {},
                  "ίδιο"
                ],
                " ",
                "γιατρό."
              ],
              " ",
              [
                "span",
                {
                  "className": "translation"
                },
                "I went to the",
                " ",
                [
                  "strong",
                  {},
                  "same"
                ],
                " ",
                "doctor."
              ]
            ],
            [
              "div",
              {
                "className": "example mt-2"
              },
              [
                "span",
                {
                  "className": "greek-text"
                },
                "Έχουμε τα",
                " ",
                [
                  "strong",
                  {},
                  "ίδια"
                ],
                " ",
                "ρούχα."
              ],
              " ",
              [
                "span",
                {
                  "className": "translation"
                },
                "We have the",
                " ",
                [
                  "strong",
                  {},
                  "same"
                ],
                " ",
                "clothes."
              ]
            ]
          ]
        ],
        [
          "div",
          {
            "className": "definite-card "
          },
          [
            "header",
            {},
            [
              "span",
              {
                "className": "greek-text"
              },
              "μόνος, μόνη, μόνο"
