      ],
      [
        "div",
        {
          "className": "info-box  mt-12 mb-12"
        },
        [
          "h3",
          {},
          "Accentuation Note"
        ],
        [
          "p",
          {},
          "In Modern Greek, one of the few words that",
          " ",
          [
            "strong",
            {},
            "always"
          ],
          " ",
          "keep their accent even when they are single-syllable are interrogative\n                words (πώς, πού, τι can be an exception but usually keeps the context).\n                The accent tells the reader \"this is a question\"."
        ]
      ]
    ]
