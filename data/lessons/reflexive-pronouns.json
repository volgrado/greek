      [
        "p",
        {},
        "Reflexive pronouns are used when the subject and the object of a\n            verb are the same person. In Greek, we use the phrase",
        " ",
        [
          "strong",
          {},
          "ο εαυτός μου"
        ],
        " ",
        "(my self)."
      ],
      [
        "div",
        {
          "className": "reflexive-showcase mt-8"
        },
        [
          "div",
          {
            "className": "person-card "
          },
          [
            "h3",
            {},
            "1st Person"
          ],
          [
            "span",
            {
              "className": "greek-text"
            },
            "ο εαυτός μου"
          ],
          " ",
          [
            "span",
            {
              "className": "translation"
            },
            "myself"
          ]
        ],
        [
          "div",
          {
            "className": "person-card "
          },
          [
            "h3",
            {},
            "2nd Person"
          ],
          [
