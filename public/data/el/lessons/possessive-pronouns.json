  [
    "h2",
    {},
    "2. Emphatic Possession (δικός)"
  ],
  [
    "p",
    {},
    [
      "The word ",
      [
        "strong",
        {},
        "δικός, δική, δικό"
      ],
      " acts like an adjective and is used to say \"mine\" or \"my own\". It must match the gender of the object being possessed."
    ]
  ],
  [
    "div",
    {
      "className": "content-grid mt-8"
    },
    [
      "p",
      {},
      "το δικό μου my own / mineτο δικό σου your own / yoursτο δικό του his own / his"
