    [
      "p",
      {},
      [
        "When using ",
        [
          "strong",
          {},
          "δικός"
        ],
        ", you often need an article before it. Think of it like saying \"the mine own\". Example: Έχω το δικό μου αυτοκίνητο. (I have my own car)."
      ]
    ]
  ]
