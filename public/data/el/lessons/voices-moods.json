[
  "div",
  {
    "className": "content-wrapper"
  },
  [
    "h1",
    {},
    "Voices and Moods"
  ],
  [
    "p",
    {},
    [
      "Greek verbs have two ",
      [
        "strong",
        {},
        "Voices"
      ],
      " (who performs/receives the action) and several ",
      [
        "strong",
        {},
        "Moods"
      ],
      " (the attitude of the speaker towards the action)."
    ]
  ],
  [
    "div",
    {
      "className": "content-grid mt-8"
    },
    [
      "h3",
      {},
      "Voices (Φωνές)"
    ],
    [
      "p",
      {},
      [
        "Ενεργητική (Active)The subject performs the action. ",
        [
          "em",
          {},
          "Εγώ πλένω"
        ],
        " (I wash)."
      ]
    ],
    [
      "p",
      {},
      [
        "Παθητική (Passive)The subject receives the action or acts on itself. ",
        [
          "em",
          {},
          "Εγώ πλένομαι"
        ],
        " (I am being washed / I wash myself)."
      ]
    ],
    [
      "h3",
      {},
      "Moods (Εγκλίσεις)"
    ],
    [
      "p",
      {},
      [
        "Οριστική (Indicative)Facts and reality. ",
        [
          "em",
          {},
          "Το παιδί παίζει"
        ],
        " (The child plays)."
      ]
    ],
    [
      "p",
      {},
      [
        "Υποτακτική (Subjunctive)Wishes, possibilities, and \"should\". Often uses ",
        [
          "strong",
          {},
          "να"
        ],
        ". ",
        [
          "em",
          {},
          "Θέλω να παίξω"
        ],
        " (I want to play)."
      ]
    ],
    [
      "p",
      {},
      [
        "Προστακτική (Imperative)Commands and requests. ",
        [
          "em",
          {},
          "Διάβασε!"
        ],
        " (Read!)."
      ]
    ]
  ],
  [
    "div",
    {
      "className": "info-box mt-12 mb-12"
    },
    [
      "h3",
      {},
      "Special Forms"
    ],
    [
      "p",
      {},
      [
        "Greek also has ",
        [
          "strong",
          {},
          "Participles"
        ],
        " (Μετοχή) ending in ",
        [
          "em",
          {},
          "-οντας"
        ],
        " (like \"-ing\" in English) and an ",
        [
          "strong",
          {},
          "Infinitive"
        ],
        " form (used in perfect tenses)."
      ]
    ]
  ]
]