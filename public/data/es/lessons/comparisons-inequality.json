[
  "div",
  {
    "className": "content-wrapper"
  },
  [
    "h1",
    {},
    "Comparisons of Inequality"
  ],
  [
    "p",
    {},
    "In Spanish, we use specific formulas to compare things that are not equal (more than or less than)."
  ],
  [
    "h2",
    {},
    "More than / Less than"
  ],
  [
    "ul",
    {
      "className": "phrase-list"
    },
    [
      "li",
      {},
      [
        "span",
        {
          "className": "spanish"
        },
        [
          [
            "strong",
            {},
            "más"
          ],
          " + [adjective/noun] + ",
          [
            "strong",
            {},
            "que"
          ]
        ]
      ],
      [
        "span",
        {
          "className": "meaning"
        },
        "more than"
      ]
    ],
    [
      "li",
      {},
      [
        "span",
        {
          "className": "spanish"
        },
        [
          [
            "strong",
            {},
            "menos"
          ],
          " + [adjective/noun] + ",
          [
            "strong",
            {},
            "que"
          ]
        ]
      ],
      [
        "span",
        {
          "className": "meaning"
        },
        "less than"
      ]
    ]
  ],
  [
    "h2",
    {},
    "Examples"
  ],
  [
    "ul",
    {
      "className": "phrase-list"
    },
    [
      "li",
      {},
      [
        "span",
        {
          "className": "spanish"
        },
        "Juan es más alto que Pedro."
      ],
      [
        "span",
        {
          "className": "meaning"
        },
        "Juan is taller than Pedro."
      ]
    ],
    [
      "li",
      {},
      [
        "span",
        {
          "className": "spanish"
        },
        "Tengo menos dinero que tú."
      ],
      [
        "span",
        {
          "className": "meaning"
        },
        "I have less money than you."
      ]
    ]
  ],
  [
    "div",
    {
      "className": "info-box"
    },
    [
      "h3",
      {},
      "Irregular Comparatives"
    ],
    [
      "p",
      {},
      "Some adjectives have their own comparative forms:"
    ],
    [
      "ul",
      {
        "className": "phrase-list"
      },
      [
        "li",
        {},
        [
          "span",
          {
            "className": "spanish"
          },
          [
            "Bueno → ",
            [
              "strong",
              {},
              "Mejor"
            ]
          ]
        ],
        [
          "span",
          {
            "className": "meaning"
          },
          "Better"
        ]
      ],
      [
        "li",
        {},
        [
          "span",
          {
            "className": "spanish"
          },
          [
            "Malo → ",
            [
              "strong",
              {},
              "Peor"
            ]
          ]
        ],
        [
          "span",
          {
            "className": "meaning"
          },
          "Worse"
        ]
      ],
      [
        "li",
        {},
        [
          "span",
          {
            "className": "spanish"
          },
          [
            "Viejo → ",
            [
              "strong",
              {},
              "Mayor"
            ]
          ]
        ],
        [
          "span",
          {
            "className": "meaning"
          },
          "Older"
        ]
      ],
      [
        "li",
        {},
        [
          "span",
          {
            "className": "spanish"
          },
          [
            "Joven → ",
            [
              "strong",
              {},
              "Menor"
            ]
          ]
        ],
        [
          "span",
          {
            "className": "meaning"
          },
          "Younger"
        ]
      ]
    ]
  ]
]