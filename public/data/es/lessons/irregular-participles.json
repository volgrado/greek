  ],
  [
    "h2",
    {},
    "The '-yendo' Group"
  ],
  [
    "p",
    {},
    [
      "When the stem of an -er or -ir verb ends in a vowel, use ",
      [
        "strong",
        {},
        "-yendo"
      ],
      " instead of -iendo."
    ]
  ],
  [
    "ul",
    {
      "className": "phrase-list"
    },
    [
      "li",
      {},
      [
        "Leer → ",
        [
          "strong",
          {},
          "leyendo"
        ]
      ]
    ],
    [
      "li",
      {},
      [
        "Oír → ",
        [
          "strong",
          {},
          "oyendo"
        ]
      ]
    ],
    [
      "li",
      {},
      [
        "Traer → ",
        [
          "strong",
          {},
          "trayendo"
        ]
      ]
    ]
  ],
  [
    "h2",
    {},
    "Stem-Changing Verbs"
  ],
