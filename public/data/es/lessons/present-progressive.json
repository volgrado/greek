[
  "div",
  {
    "className": "content-wrapper"
  },
  [
    "h1",
    {},
    "Present Progressive"
  ],
  [
    "p",
    {},
    [
      "The present progressive is used to describe an action that is happening ",
      [
        "strong",
        {},
        "right now"
      ],
      "."
    ]
  ],
  [
    "h2",
    {},
    "The Formula"
  ],
  [
    "p",
    {},
    [
      "Formula: ",
      [
        "strong",
        {},
        "Estar + Present Participle (-ando / -iendo)"
      ]
    ]
  ],
  [
    "ul",
    {
      "className": "phrase-list"
    },
    [
      "li",
      {},
      [
        "span",
        {
          "className": "spanish"
        },
        [
          "For -ar verbs: replace -ar with ",
          [
            "strong",
            {},
            "-ando"
          ]
        ]
      ],
      [
        "span",
        {
          "className": "meaning"
        },
        "hablar → hablando"
      ]
    ],
    [
      "li",
      {},
      [
        "span",
        {
          "className": "spanish"
        },
        [
          "For -er/-ir verbs: replace -er/-ir with ",
          [
            "strong",
            {},
            "-iendo"
          ]
        ]
      ],
      [
        "span",
        {
          "className": "meaning"
        },
        "comer → comiendo / vivir → viviendo"
      ]
    ]
  ],
  [
    "h2",
    {},
    "Examples"
  ],
  [
    "ul",
    {
      "className": "phrase-list"
    },
    [
      "li",
      {},
      [
        "span",
        {
          "className": "spanish"
        },
